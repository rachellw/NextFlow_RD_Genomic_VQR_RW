{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://raw.githubusercontent.com/rachellw/NextFlow_RD_Genomic_VQR_RW/entry_points/nextflow_schema.json",
  "title": "Nextflow pipeline parameters",
  "description": "This pipeline uses Nextflow and processes exome or genome data.",
  "type": "object",
  "definitions": {
    "inputs_outputs": {
      "title": "inputs_outputs",
      "type": "object",
      "properties": {
        "platform": {
          "type": "string",
          "description": "Platform used to generate the data",
          "default": "local",
          "enum": ["local", "cloud"]
        },
        "samplesheet": {
          "type": "string",
          "format": "file-path",
          "description": "Samplesheet containing FASTQ files"
        },
        "bam_no_index_samplesheet": {
          "type": "string",
          "format": "file-path",
          "description": "Samplesheet listing deduplicated BAM files without BAM index"
        },
        "bam_samplesheet": {
          "type": "string",
          "format": "file-path",
          "description": "Samplesheet listing deduplicated BAM and BAI files"
        },
        "gvcf_samplesheet": {
          "type": "string",
          "format": "file-path",
          "description": "Samplesheet listing gVCF and gVCF index files"
        },
        "genome_index_files": {
          "type": "string",
          "description": "Genome index files directory",
          "format": "directory-path"
        },
        "qsrVcfs": {
          "type": "string",
          "description": "Quality Score Recalibration files directory",
          "format": "directory-path"
        },
        "genome_file": {
          "type": "string",
          "description": "Genome fasta file",
          "default": "genome.fasta",
          "format": "file-path"
        },
        "outdir": {
          "type": "string",
          "description": "Output directory",
          "default": "./results",
          "format": "directory-path"
        },
        "aligner": {
          "type": "string",
          "description": "Aligner to use",
          "default": "bwa-mem",
          "enum": ["bwa-mem", "bwa-aln"]
        },
        "variant_caller": {
          "type": "string",
          "description": "Variant caller to use",
          "default": "haplotype-caller",
          "enum": ["haplotype-caller", "deepvariant"]
        },
        "fastqc": {
          "type": "boolean",
          "description": "Run FASTQC",
          "default": false
        },
        "fastp": {
          "type": "boolean",
          "description": "Run FASTP",
          "default": false
        },
        "index_genome": {
          "type": "boolean",
          "description": "Index the genome if not already done",
          "default": false
        },
        "degraded_dna": {
          "type": "boolean",
          "description": "Perform degraded DNA analysis",
          "default": false
        },
        "bqsr": {
          "type": "boolean",
          "description": "Perform Base Quality Score Recalibration",
          "default": false
        },
        "variant_recalibration": {
          "type": "boolean",
          "description": "Perform variant recalibration",
          "default": false
        },
        "identity_analysis": {
          "type": "boolean",
          "description": "Perform identity analysis",
          "default": false
        }
      },
      "required": [
        "platform",
        "genome_index_files",
        "index_genome",
        "genome_file",
        "qsrVcfs",
        "outdir",
        "aligner",
        "bqsr",
        "fastqc",
        "variant_recalibration",
        "identity_analysis",
        "degraded_dna",
        "variant_caller"
      ]
    }
  },
  "allOf": [
    {
      "$ref": "#/definitions/inputs_outputs"
    },
    {
      "oneOf": [
        { "required": ["samplesheet"] },
        { "required": ["bam_no_index_samplesheet"] },
        { "required": ["bam_samplesheet"] },
        { "required": ["gvcf_samplesheet"] }
      ]
    }
  ]
}